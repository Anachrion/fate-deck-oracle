<!-- Results Card -->
<% if duel_data %>
  <div class="bg-white/10 backdrop-blur-lg rounded-2xl p-8 shadow-2xl border border-white/20">
    <div class="text-center mb-8">
      <h2 class="text-3xl font-bold text-white mb-2">
        Success Rate: 
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-green-400 to-emerald-400">
          <%= duel_data && duel_data[:global_success_rate] %>%
        </span>
      </h2>
      
      <h3 class="text-xl text-slate-300 mb-6">
        With a raise: 
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-cyan-400">
          <%= duel_data && duel_data[:global_success_rate_with_raise] %>%
        </span>
      </h3>
    </div>
    
    <div class="bg-white/5 rounded-xl p-6 border border-white/10">
      <h4 class="text-lg font-semibold text-white mb-4 text-center">Duel Details</h4>
      <div class="space-y-4">
        <div class="flex justify-between items-center py-3 px-4 bg-white/5 rounded-lg">
          <span class="text-slate-300 font-medium">Duel Type:</span>
          <span class="text-white font-bold text-lg capitalize"><%= duel_data && duel_data[:duel_type] %></span>
        </div>
        
        <div class="flex justify-between items-center py-3 px-4 bg-white/5 rounded-lg">
          <span class="text-slate-300 font-medium">Attacker Value:</span>
          <span class="text-white font-bold text-lg"><%= duel_data && duel_data[:attacker_stat] %></span>
        </div>
        
        <% if duel_data && duel_data[:duel_type] == 'opposed' %>
          <div class="flex justify-between items-center py-3 px-4 bg-white/5 rounded-lg">
            <span class="text-slate-300 font-medium">Defender Value:</span>
            <span class="text-white font-bold text-lg"><%= duel_data && duel_data[:defender_stat] %></span>
          </div>
        <% elsif duel_data && duel_data[:duel_type] == 'opposed_with_tn' %>
          <div class="flex justify-between items-center py-3 px-4 bg-white/5 rounded-lg">
            <span class="text-slate-300 font-medium">Defender Value:</span>
            <span class="text-white font-bold text-lg"><%= duel_data && duel_data[:defender_stat] %></span>
          </div>
          <div class="flex justify-between items-center py-3 px-4 bg-white/5 rounded-lg">
            <span class="text-slate-300 font-medium">Target Number:</span>
            <span class="text-white font-bold text-lg"><%= duel_data && duel_data[:target_number] %></span>
          </div>
        <% else %>
          <div class="flex justify-between items-center py-3 px-4 bg-white/5 rounded-lg">
            <span class="text-slate-300 font-medium">Target Number:</span>
            <span class="text-white font-bold text-lg"><%= duel_data && duel_data[:target_number] %></span>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>